{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build PDF (current file)",
      "type": "shell",
      "command": "pandoc",
      "args": [
        "${file}",
        "--defaults=pandoc/defaults.yaml",
        "--template=pandoc/templates/default.latex",
        "--resource-path=.:${fileDirname}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.pdf"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build HTML (current file)",
      "type": "shell",
      "command": "pandoc",
      "args": [
        "${file}",
        "--defaults=pandoc/defaults.yaml",
        "--template=pandoc/templates/default.html",
        "--css=pandoc/style.css",
        "--resource-path=.:${fileDirname}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.html"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build LaTeX (current file)",
      "type": "shell",
      "command": "pandoc",
      "args": [
        "${file}",
        "--defaults=pandoc/defaults.yaml",
        "--template=pandoc/templates/default.latex",
        "--resource-path=.:${fileDirname}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.tex"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build DOCX (current file)",
      "type": "shell",
      "command": "python3",
      "args": [
        "pandoc/build.py",
        "${file}"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build PDF (project)",
      "type": "shell",
      "command": "python3",
      "args": [
        "pandoc/build.py",
        "--project",
        "-o",
        "output.pdf"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build HTML (project)",
      "type": "shell",
      "command": "python3",
      "args": [
        "pandoc/build.py",
        "--project",
        "-o",
        "output.html"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build DOCX (project)",
      "type": "shell",
      "command": "python3",
      "args": [
        "pandoc/build.py",
        "--project",
        "-o",
        "output.docx"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build Slides (PDF/Beamer from current file)",
      "type": "shell",
      "command": "pandoc",
      "args": [
        "${file}",
        "--defaults=pandoc/defaults.yaml",
        "-t",
        "beamer",
        "--pdf-engine=lualatex",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.pdf"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build Slides (HTML/Slidy from current file)",
      "type": "shell",
      "command": "pandoc",
      "args": [
        "${file}",
        "--defaults=pandoc/defaults.yaml",
        "-t",
        "slidy",
        "--embed-resources",
        "--standalone",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.html"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build Slides (PPTX from current file)",
      "type": "shell",
      "command": "pandoc",
      "args": [
        "${file}",
        "--defaults=pandoc/defaults.yaml",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.pptx"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Check glossing abbreviations",
      "type": "shell",
      "command": "python3",
      "args": [
        "check_gloss_markup.py",
        "output.html"
      ],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run tests",
      "type": "shell",
      "command": "pytest",
      "args": [
        "-v"
      ],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Clean outputs",
      "type": "shell",
      "command": "rm",
      "args": [
        "-f",
        "output.pdf",
        "output.html",
        "output.docx",
        "output.tex",
        "demo.pdf",
        "demo.html",
        "demo.docx",
        "demo.tex",
        "slides.pdf",
        "slides.html",
        "slides.pptx"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
