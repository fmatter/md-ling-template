{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build PDF (current file)",
      "type": "shell",
      "command": "pandoc",
      "args": [
        "${file}",
        "--defaults=pandoc/defaults.yaml",
        "--template=pandoc/templates/default.latex",
        "--resource-path=.:${fileDirname}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.pdf"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build PDF (multi-file with metadata.yaml)",
      "type": "shell",
      "command": "pandoc",
      "args": [
        "01-intro.md",
        "02-chapter.md",
        "03-conclusion.md",
        "--defaults=pandoc/defaults.yaml",
        "--metadata-file=metadata.yaml",
        "--template=pandoc/templates/default.latex",
        "-o",
        "article.pdf"
      ],
      "group": "build",
      "options": {
        "cwd": "${fileDirname}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build with Makefile",
      "type": "shell",
      "command": "make",
      "args": [
        "pdf"
      ],
      "group": "build",
      "options": {
        "cwd": "${fileDirname}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build HTML (multi-file with metadata.yaml)",
      "type": "shell",
      "command": "pandoc",
      "args": [
        "01-intro.md",
        "02-chapter.md",
        "03-conclusion.md",
        "--defaults=pandoc/defaults.yaml",
        "--metadata-file=metadata.yaml",
        "-o",
        "article.html"
      ],
      "group": "build",
      "options": {
        "cwd": "${fileDirname}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build HTML (current file)",
      "type": "shell",
      "command": "pandoc",
      "args": [
        "${file}",
        "--defaults=pandoc/defaults.yaml",
        "--template=pandoc/templates/default.html",
        "--css=pandoc/style.css",
        "--resource-path=.:${fileDirname}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.html"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build LaTeX (current file)",
      "type": "shell",
      "command": "pandoc",
      "args": [
        "${file}",
        "--defaults=pandoc/defaults.yaml",
        "--template=pandoc/templates/default.latex",
        "--resource-path=.:${fileDirname}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.tex"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build DOCX (current file)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "pandoc '${file}' --defaults=pandoc/defaults.yaml --resource-path=.:${fileDirname} -o '${fileDirname}/${fileBasenameNoExtension}.docx' && python3 pandoc/filters/fix_docx.py '${fileDirname}/${fileBasenameNoExtension}.docx'"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build DOCX (multi-file with metadata.yaml)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "pandoc 01-intro.md 02-chapter.md 03-conclusion.md --defaults=pandoc/defaults.yaml --metadata-file=metadata.yaml -o article.docx && python3 ../pandoc/filters/fix_docx.py article.docx"
      ],
      "group": "build",
      "options": {
        "cwd": "${fileDirname}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build Slides (PDF/Beamer)",
      "type": "shell",
      "command": "pandoc",
      "args": [
        "blueprints/slides.md",
        "--defaults=pandoc/defaults.yaml",
        "-t",
        "beamer",
        "--pdf-engine=lualatex",
        "-o",
        "slides.pdf"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build Slides (HTML/Slidy)",
      "type": "shell",
      "command": "pandoc",
      "args": [
        "blueprints/slides.md",
        "--defaults=pandoc/defaults.yaml",
        "-t",
        "slidy",
        "--embed-resources",
        "--standalone",
        "-o",
        "slides.html"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build Slides (PPTX)",
      "type": "shell",
      "command": "pandoc",
      "args": [
        "blueprints/slides.md",
        "--defaults=pandoc/defaults.yaml",
        "-o",
        "slides.pptx"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run tests",
      "type": "shell",
      "command": "pytest",
      "args": [
        "-v"
      ],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Clean outputs",
      "type": "shell",
      "command": "find",
      "args": [
        ".",
        "-type",
        "f",
        "(",
        "-name",
        "*.pdf",
        "-o",
        "-name",
        "*.html",
        "-o",
        "-name",
        "*.tex",
        "-o",
        "-name",
        "*.docx",
        ")",
        "-not",
        "-path",
        "*/pandoc/*",
        "-not",
        "-path",
        "*/tests/*",
        "-delete"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
